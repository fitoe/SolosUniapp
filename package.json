{
  "name": "solos-uniapp",
  "type": "module",
  "version": "0.0.2",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -m wechat -p mp-weixin",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -m wechatproduction -p mp-weixin && node ./scripts/check-build-outputs.mjs",
    "build": "pnpm build:mp-weixin",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:mp:smoke": "node ./scripts/mp-weixin-smoke.mjs",
    "upload:mp": "node ./scripts/upload-weixin.mjs --target=weixin",
    "debug:mp:enable": "node ./scripts/wechat-devtools-enable.mjs",
    "debug:mp:inspect": "node ./scripts/wechat-devtools.mjs inspect",
    "debug:mp:screenshot": "node ./scripts/wechat-devtools.mjs screenshot",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@alova/adapter-uniapp": "^2.0.15",
    "@alova/shared": "^1.3.2",
    "@dcloudio/uni-app": "3.0.0-4080720251210001",
    "@dcloudio/uni-components": "3.0.0-4080720251210001",
    "@dcloudio/uni-h5": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080720251210001",
    "@qiun/ucharts": "2.5.0-20230101",
    "@vueuse/core": "^13.9.0",
    "@vueuse/shared": "^13.9.0",
    "alova": "^3.5.0",
    "pinia": "2.0.36",
    "pinia-plugin-persist-uni": "^1.3.2",
    "vue": "^3.4.21",
    "wot-design-uni": "^1.14.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080720251210001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080720251210001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080720251210001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080720251210001",
    "@iconify-json/carbon": "^1.2.20",
    "@iconify-json/mdi": "^1.2.3",
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.5.0",
    "@uni-helper/eslint-config": "^0.6.1",
    "@uni-helper/plugin-uni": "^0.1.0",
    "@uni-helper/uni-app-types": "^1.0.0-alpha.7",
    "@uni-helper/uni-use": "^0.19.17",
    "@uni-helper/unocss-preset-uni": "0.2.11",
    "@uni-helper/vite-plugin-uni-components": "^0.2.3",
    "@uni-helper/vite-plugin-uni-layouts": "^0.1.11",
    "@uni-helper/vite-plugin-uni-manifest": "^0.2.12",
    "@uni-helper/vite-plugin-uni-pages": "^0.3.19",
    "@unocss/eslint-config": "0.65.4",
    "@unocss/preset-icons": "0.65.4",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/runtime-core": "^3.4.21",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "jsdom": "^26.1.0",
    "miniprogram-automator": "0.12.1",
    "miniprogram-ci": "^2.1.26",
    "sass": "1.78.0",
    "typescript": "^5.9.3",
    "unocss": "0.65.4",
    "unocss-applet": "0.9.0",
    "unplugin-auto-import": "^21.0.0",
    "vite": "5.2.8",
    "vite-plugin-uni-polyfill": "^0.1.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.2"
  },
  "starter_contract": {
    "ui_library": "wot-design-uni",
    "request_library": "alova",
    "features": [
      "home-playground",
      "chart"
    ]
  }
}
