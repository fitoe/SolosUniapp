{
  "name": "uniapp-starter-v1",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "release:check": "pnpm clean && pnpm type-check && pnpm lint && pnpm test && pnpm build:all-mini && pnpm smoke:build-mini",
    "predev:h5": "node ./scripts/validate-env.mjs",
    "predev:mp-weixin": "node ./scripts/validate-env.mjs",
    "predev:mp-toutiao": "node ./scripts/validate-env.mjs",
    "predev:mp-kuaishou": "node ./scripts/validate-env.mjs",
    "predev:mp-xhs": "node ./scripts/validate-env.mjs",
    "prebuild:h5": "node ./scripts/validate-env.mjs",
    "prebuild:mp-weixin": "node ./scripts/validate-env.mjs",
    "prebuild:mp-toutiao": "node ./scripts/validate-env.mjs",
    "prebuild:mp-kuaishou": "node ./scripts/validate-env.mjs",
    "prebuild:mp-xhs": "node ./scripts/validate-env.mjs",
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -m wechat -p mp-weixin",
    "dev:mp-toutiao": "uni -m wechat -p mp-toutiao",
    "dev:mp-kuaishou": "uni -m wechat -p mp-kuaishou",
    "dev:mp-xhs": "uni -m wechat -p mp-xhs",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -m wechatproduction -p mp-weixin",
    "build:mp-toutiao": "uni build -m wechatproduction -p mp-toutiao",
    "build:mp-kuaishou": "uni build -m wechatproduction -p mp-kuaishou",
    "build:mp-xhs": "uni build -m wechatproduction -p mp-xhs",
    "build:all-mini": "pnpm build:mp-weixin && pnpm build:mp-toutiao && pnpm build:mp-kuaishou && pnpm build:mp-xhs",
    "smoke:build-mini": "node ./scripts/check-build-outputs.mjs",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "upload:all": "node ./scripts/upload-all.mjs",
    "upload:douyin": "node ./scripts/upload-douyin.mjs",
    "upload:kuaishou": "node ./scripts/upload-kuaishou.mjs",
    "upload:mp": "node ./scripts/upload-weixin.mjs --target=weixin",
    "upload:xhs": "node ./scripts/upload-xhs.mjs",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@alova/adapter-uniapp": "^2.0.15",
    "@alova/shared": "^1.3.2",
    "@dcloudio/uni-app": "3.0.0-4080720251210001",
    "@dcloudio/uni-app-harmony": "3.0.0-4080720251210001",
    "@dcloudio/uni-app-plus": "3.0.0-4080720251210001",
    "@dcloudio/uni-components": "3.0.0-4080720251210001",
    "@dcloudio/uni-h5": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-baidu": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-harmony": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-jd": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-lark": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-qq": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080720251210001",
    "@dcloudio/uni-mp-xhs": "3.0.0-4080720251210001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-4080720251210001",
    "@dcloudio/uni-ui": "^1.5.11",
    "@qiun/ucharts": "2.5.0-20230101",
    "@vueuse/core": "^13.9.0",
    "@vueuse/shared": "^13.9.0",
    "alova": "^3.5.0",
    "pinia": "2.0.36",
    "pinia-plugin-persist-uni": "^1.3.2",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080720251210001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080720251210001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080720251210001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080720251210001",
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.5.0",
    "@uni-helper/eslint-config": "^0.6.1",
    "@uni-helper/uni-app-types": "^1.0.0-alpha.7",
    "@uni-helper/uni-use": "^0.19.17",
    "@uni-helper/vite-plugin-uni-components": "^0.2.6",
    "@uni-helper/vite-plugin-uni-layouts": "^0.1.11",
    "@uni-helper/vite-plugin-uni-manifest": "^0.2.12",
    "@uni-helper/vite-plugin-uni-pages": "^0.3.23",
    "@unocss/eslint-config": "^66.6.0",
    "@unocss/preset-icons": "^66.6.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/runtime-core": "^3.4.21",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "jsdom": "^26.1.0",
    "ks-miniprogram-ci": "^1.3.15",
    "miniprogram-ci": "^2.1.26",
    "sass": "1.78.0",
    "tt-ide-cli": "^0.1.31",
    "typescript": "^5.9.3",
    "unocss": "^66.5.2",
    "unplugin-auto-import": "^21.0.0",
    "vite": "5.2.8",
    "vite-plugin-uni-polyfill": "^0.1.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.2",
    "xhs-mp-cli": "^1.0.12"
  },
  "starter_contract": {
    "ui_library": "uni-ui",
    "request_library": "alova",
    "features": [
      "auth",
      "chart"
    ]
  }
}
