{
  "project": {
    "name": "SolosUniapp",
    "type": "starter-template",
    "status": "ready",
    "stack": ["uni-app", "vue3", "typescript", "vite", "uni-helper", "unocss"],
    "constraints": {
      "ui_library": "none",
      "request_library": "alova",
      "features_enabled": ["basic-home"]
    }
  },
  "platforms": ["h5", "mp-weixin"],
  "entrypoints": {
    "app": "src/main.ts",
    "vite": "vite.config.ts",
    "pages": "pages.config.ts",
    "manifest": "manifest.config.ts",
    "targets": "config/targets.ts"
  },
  "modules": {
    "request": [
      "src/core/request/alova.ts",
      "src/core/request/http.ts"
    ],
    "upload": [
      "scripts/upload-weixin.mjs",
      "scripts/upload-all.mjs"
    ]
  },
  "commands": {
    "install": "pnpm i",
    "check": ["pnpm type-check", "pnpm lint"],
    "test": ["pnpm test:unit", "pnpm test:e2e", "pnpm test:mp:smoke"],
    "dev": [
      "pnpm dev:h5",
      "pnpm dev:mp-weixin"
    ],
    "build": ["pnpm build", "pnpm build:h5", "pnpm build:mp-weixin"],
    "upload": [
      "pnpm upload:mp"
    ]
  },
  "automation": {
    "wechat_devtools": {
      "sdk": "miniprogram-automator",
      "wrapper": "scripts/wechat-devtools.mjs",
      "enable_entry": "scripts/wechat-devtools-enable.mjs",
      "default_project_path": "dist/dev/mp-weixin",
      "default_auto_port": 9420,
      "agent_rule": [
        "Auto-enable only when the task actually needs Wechat DevTools debugging for mp-weixin",
        "Require dist/dev/mp-weixin to exist; otherwise ask user to run pnpm dev:mp-weixin first",
        "Use scripts/wechat-devtools-enable.mjs on Windows",
        "Use node ./scripts/wechat-devtools.mjs inspect for page stack and current page",
        "Use node ./scripts/wechat-devtools.mjs screenshot for screenshots",
        "Use pnpm test:mp:smoke for mp-weixin smoke validation after the project is connected",
        "If connection fails, tell user to verify DevTools opened dist/dev/mp-weixin and enabled the service port in security settings"
      ]
    },
    "shell_preference": {
      "windows_default": "git-bash-preferred",
      "git_bash_path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "fallback_env": "GIT_BASH_PATH",
      "use_git_bash_for": [
        "commands containing && or ||",
        "inline environment variable assignment",
        "pipes, globbing, redirection, and .sh scripts",
        "multi-step shell workflows better expressed in POSIX shell"
      ],
      "keep_powershell_for": [
        "Get-ChildItem",
        "Get-Process",
        "Get-NetTCPConnection",
        "other Windows-native inspection commands"
      ]
    }
  },
  "env": {
    "examples": ["env/.env.example", "env/.env.wechat.example"],
    "required_base": [
      "VITE_API_HOST",
      "VITE_API_PATH",
      "VITE_UPLOAD_HOST",
      "VITE_UPLOAD_PATH"
    ],
    "required_platform": [
      "VITE_APPID_WEIXIN",
      "VITE_PROJECT_NAME_WEIXIN"
    ],
    "required_upload_secrets": {
      "weixin": [
        "WX_PRIVATE_KEY_PATH_WEIXIN",
        "WX_PRIVATE_KEY_WEIXIN_BASE64",
        "WX_PRIVATE_KEY_WEIXIN"
      ]
    }
  },
  "ci": {
    "workflows": [
      ".github/workflows/mini-build.yml",
      ".github/workflows/upload-weixin.yml",
      ".github/workflows/upload-all-mini.yml"
    ]
  },
  "bootstrap_steps": [
    "Read AGENTS.md",
    "Read README.md",
    "Read TESTING_POLICY.md",
    "Install dependencies",
    "Run type-check",
    "Run lint"
  ],
  "testing_policy": {
    "unit_framework": "vitest",
    "e2e_framework": "playwright",
    "mandatory": true,
    "rules": [
      "Every component/page change must include tests",
      "Component changes require unit tests",
      "Page changes require unit + e2e tests"
    ],
    "files": ["TESTING_POLICY.md", "vitest.config.ts", "playwright.config.ts"]
  },
  "last_updated": "2026-03-23"
}
